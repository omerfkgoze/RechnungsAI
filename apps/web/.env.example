NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-start
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-start

# Google OAuth (Supabase Auth external provider)
# Generate a Google OAuth client at https://console.cloud.google.com/apis/credentials with authorized redirect URI http://127.0.0.1:54321/auth/v1/callback (local) and https://<prod-host>/auth/v1/callback (prod).
SUPABASE_AUTH_GOOGLE_CLIENT_ID=your-google-oauth-client-id
SUPABASE_AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Sentry Error Monitoring — @sentry/nextjs
# Create a project at https://sentry.io and copy the DSN from Project Settings > Client Keys.
# SENTRY_AUTH_TOKEN is only needed for source map uploads in CI/CD (optional locally).
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token-for-ci

# AI Provider — Epic 2 Invoice Extraction
# Used by @ai-sdk/openai in packages/ai. Get your key at https://platform.openai.com/api-keys
# NFR13: use a zero-retention endpoint (configure in packages/ai/src/provider.ts if needed).
OPENAI_API_KEY=your-openai-api-key
# Optional — override extraction model. Default: gpt-4o-mini (widest project access, supports vision + PDF).
# Other options: gpt-4o, gpt-4.1, gpt-4.1-mini. Verify your project has access before switching.
# OPENAI_EXTRACTION_MODEL=gpt-4o-mini
