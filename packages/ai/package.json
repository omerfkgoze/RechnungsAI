{
  "name": "@rechnungsai/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --build --watch",
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@rechnungsai/shared": "workspace:*",
    "ai": "^6.0.168"
  },
  "devDependencies": {
    "@rechnungsai/eslint-config": "workspace:*",
    "@rechnungsai/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.4"
  }
}
